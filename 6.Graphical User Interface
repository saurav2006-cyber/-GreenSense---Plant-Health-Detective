"""
GreenSense GUI Application
"""

import tkinter as tk
from tkinter import ttk, filedialog, messagebox, scrolledtext
from PIL import Image, ImageTk
import threading
from pathlib import Path

from plant_detector import PlantHealthDetector

class GreenSenseGUI:
    def __init__(self, root):
        self.root = root
        self.root.title("GreenSense - Plant Health Detective 🌱")
        self.root.geometry("1200x700")
        
        self.detector = PlantHealthDetector()
        self.current_image_path = None
        
        self.setup_ui()
        
    def setup_ui(self):
        # Main container
        main_frame = ttk.Frame(self.root, padding="10")
        main_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S))
        
        # Title
        title_label = ttk.Label(main_frame, text="🌱 GreenSense - Plant Health Detective", 
                                font=('Arial', 20, 'bold'))
        title_label.grid(row=0, column=0, columnspan=2, pady=10)
        
        # Left panel - Image controls
        left_panel = ttk.Frame(main_frame)
        left_panel.grid(row=1, column=0, padx=10, sticky=(tk.W, tk.E, tk.N, tk.S))
        
        # Image display
        self.image_label = ttk.Label(left_panel, text="No image loaded", 
                                     relief="solid", width=50, height=20)
        self.image_label.grid(row=0, column=0, pady=10)
        
        # Buttons
        ttk.Button(left_panel, text="📸 Load Image", 
                   command=self.load_image).grid(row=1, column=0, pady=5)
        
        ttk.Button(left_panel, text="🔍 Analyze Plant", 
                   command=self.analyze_plant).grid(row=2, column=0, pady=5)
        
        # Plant name input
        ttk.Label(left_panel, text="Plant Name (optional):").grid(row=3, column=0, pady=5)
        self.plant_name_var = tk.StringVar()
        plant_entry = ttk.Entry(left_panel, textvariable=self.plant_name_var, width=30)
        plant_entry.grid(row=4, column=0, pady=5)
        
        # Right panel - Results
        right_panel = ttk.Frame(main_frame)
        right_panel.grid(row=1, column=1, padx=10, sticky=(tk.W, tk.E, tk.N, tk.S))
        
        # Results display
        self.results_text = scrolledtext.ScrolledText(right_panel, width=50, height=25, 
                                                      font=('Courier', 10))
        self.results_text.grid(row=0, column=0, pady=10)
        
        # Status bar
        self.status_var = tk.StringVar()
        self.status_var.set("Ready")
        status_bar = ttk.Label(main_frame, textvariable=self.status_var, 
                               relief=tk.SUNKEN, anchor=tk.W)
        status_bar.grid(row=2, column=0, columnspan=2, sticky=(tk.W, tk.E), pady=10)
        
        # Configure grid weights
        self.root.columnconfigure(0, weight=1)
        self.root.rowconfigure(0, weight=1)
        main_frame.columnconfigure(1, weight=1)
        main_frame.rowconfigure(1, weight=1)
    
    def load_image(self):
        """Load image from file"""
        file_path = filedialog.askopenfilename(
            title="Select Plant Image",
            filetypes=[
                ("Image files", "*.jpg *.jpeg *.png *.bmp"),
                ("All files", "*.*")
            ]
        )
        
        if file_path:
            self.current_image_path = file_path
            self.display_image(file_path)
            self.status_var.set(f"Loaded: {Path(file_path).name}")
    
    def display_image(self, image_path):
        """Display image in GUI"""
        # Load and resize image
        img = Image.open(image_path)
        img.thumbnail((400, 400))
        photo = ImageTk.PhotoImage(img)
        
        self.image_label.config(image=photo)
        self.image_label.image = photo  # Keep a reference
    
    def analyze_plant(self):
        """Analyze the loaded plant image"""
        if not self.current_image_path:
            messagebox.showwarning("No Image", "Please load an image first!")
            return
        
        # Disable button during analysis
        self.status_var.set("Analyzing... Please wait")
        
        # Run analysis in separate thread
        def analyze():
            try:
                plant_name = self.plant_name_var.get() if self.plant_name_var.get() else None
                report = self.detector.analyze_plant(self.current_image_path, plant_name)
                
                # Update GUI in main thread
                self.root.after(0, self.display_results, report)
                
            except Exception as e:
                self.root.after(0, messagebox.showerror, "Error", f"Analysis failed: {str(e)}")
                self.root.after(0, lambda: self.status_var.set("Error occurred"))
        
        threading.Thread(target=analyze, daemon=True).start()
    
    def display_results(self, report):
        """Display analysis results"""
        self.results_text.delete(1.0, tk.END)
        
        # Format results
        results = f"""
{'='*50}
🌿 PLANT HEALTH REPORT
{'='*50}

📸 Image: {Path(report['image_path']).name}
🪴 Plant: {report['plant_name'] or 'Unknown'}

🔬 DIAGNOSIS
{'='*30}
Condition: {report['diagnosis']['condition'].replace('_', ' ').upper()}
Severity: {report['diagnosis']['severity'].upper()}
Confidence: {report['diagnosis']['confidence']:.1%}

⚠️ URGENT: {'YES' if report['urgent'] else 'NO'}

📊 KEY INDICATORS
{'='*30}
Yellowing Area: {report['features']['yellowing_area']:.1f}%
Brown Area: {report['features']['brown_area']:.1f}%
Number of Spots: {report['features']['num_spots']}

💡 RECOMMENDATIONS
{'='*30}
"""
        
        for i, rec in enumerate(report['recommendations'], 1):
            results += f"{i}. {rec}\n"
        
        results += f"""
{'='*50}
Analysis completed at: {report['timestamp']}
{'='*50}
"""
        
        self.results_text.insert(1.0, results)
        self.status_var.set("Analysis complete!")
        
        # Show popup for urgent cases
        if report['urgent']:
            messagebox.showwarning(
                "Urgent Action Required!",
                "Your plant needs immediate attention!\nCheck recommendations now."
            )
